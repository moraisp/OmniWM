+    private func isVisibleInCurrentViewport(
+        _ window: NiriWindow,
+        token: WindowToken,
+        workspaceId: WorkspaceDescriptor.ID,
+        currentWorkspaceId: WorkspaceDescriptor.ID?,
+        monitor: Monitor
+    ) -> Bool {
+        guard let controller else { return false }
+        guard workspaceId == currentWorkspaceId else { return false }
+        guard controller.workspaceManager.hiddenState(for: token) == nil else { return false }
+        guard let frame = window.renderedFrame ?? window.frame else { return false }
+
+        let viewportFrame = controller.insetWorkingFrame(for: monitor)
+        guard frame.intersects(viewportFrame) else { return false }
+        let visibleFrame = frame.intersection(viewportFrame)
+        return visibleFrame.width >= 1.0 && visibleFrame.height >= 1.0
+    }
